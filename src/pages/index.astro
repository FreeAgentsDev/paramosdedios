---
import Layout from '../layouts/Layout.astro';

// ⚠️ REEMPLAZA ESTE NÚMERO con el número real de WhatsApp del negocio
// Formato: código de país + número (sin +, espacios ni guiones)
// Ejemplo Colombia: 573101234567  →  57 (Colombia) + 310 1234567
const WHATSAPP_NUMBER = '573001234567';
const WHATSAPP_MESSAGE = encodeURIComponent(
  '¡Hola! 👋 Me interesa conocer más sobre Los Páramos de Dios. ¿Podría darme información sobre las experiencias y precios disponibles?'
);
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MESSAGE}`;

const navLinks = [
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#experiencias', label: 'Experiencias' },
  { href: '#galeria', label: 'Galería' },
  { href: '#contacto', label: 'Contacto' },
];

const experiences = [
  {
    emoji: '🐴',
    badge: 'Aventura',
    title: 'Cabalgata por el Páramo',
    description:
      'Recorre los senderos únicos del páramo a caballo, entre frailejones centenarios y vistas espectaculares hacia el Nevado del Ruiz.',
  },
  {
    emoji: '🌿',
    badge: 'Naturaleza',
    title: 'Senderismo Ecológico',
    description:
      'Explora a pie la biodiversidad única del páramo, uno de los ecosistemas más valiosos y biodiversos del planeta.',
  },
  {
    emoji: '🏠',
    badge: 'Hospedaje',
    title: 'Alojamiento Rústico',
    description:
      'Descansa en nuestra cabaña tradicional en pleno páramo. Una experiencia auténtica de vida campesina a más de 3.900 msnm.',
  },
  {
    emoji: '🍲',
    badge: 'Cultura',
    title: 'Gastronomía Campesina',
    description:
      'Saborea comida típica de la región, preparada con productos frescos y recetas tradicionales directamente en el páramo.',
  },
];

const features = [
  {
    icon: '🌿',
    title: 'Ecosistema Único',
    desc: 'Páramo en área protegida del Nevado del Ruiz, joya natural de Colombia',
  },
  {
    icon: '🐴',
    title: 'Guías Nativos',
    desc: 'Nacidos y criados en el páramo con décadas de experiencia local',
  },
  {
    icon: '🏔️',
    title: '+3.900 msnm',
    desc: 'Altitud excepcional con vistas únicas hacia el Nevado del Ruiz',
  },
  {
    icon: '♻️',
    title: 'Turismo Sostenible',
    desc: 'Comprometidos con el cuidado y preservación del ecosistema',
  },
  {
    icon: '🍲',
    title: '100% Auténtico',
    desc: 'Comida y tradiciones campesinas genuinas de Manizales y Caldas',
  },
  {
    icon: '📱',
    title: 'Atención Directa',
    desc: 'Reservas y consultas directamente por WhatsApp, sin intermediarios',
  },
];

const galleryImages = [
  { src: '/img/nevado-ruiz.jpeg',    title: 'El Nevado del Ruiz',         desc: 'Vista panorámica desde el páramo de frailejones' },
  { src: '/img/hiker-valley.jpeg',   title: 'Mirando el valle',           desc: 'La cabaña desde las alturas del páramo' },
  { src: '/img/hero.jpeg',           title: 'Cabalgata por el páramo',    desc: 'Entre frailejones y montañas del Nevado del Ruiz' },
  { src: '/img/frailejon-lake.jpeg', title: 'Laguna de frailejones',      desc: 'Ecosistema único y biodiverso del páramo' },
  { src: '/img/valley-aerial.jpeg',  title: 'Valle del páramo',           desc: 'Paisaje de la finca desde las alturas' },
  { src: '/img/group-hikers.jpeg',   title: 'Grupo de senderistas',       desc: 'Aventureros listos para explorar el páramo' },
  { src: '/img/caravan-snow.jpeg',   title: 'Caravana en la nieve',       desc: 'Expedición guiada entre frailejones nevados' },
  { src: '/img/aerial-cabin.jpeg',   title: 'La cabaña y la laguna',      desc: 'Vista aérea de las instalaciones' },
  { src: '/img/cabin.jpeg',          title: 'Cabaña en el páramo',        desc: 'Refugio rústico rodeado de montañas' },
  { src: '/img/river-mountains.jpeg',title: 'Río del páramo',             desc: 'Aguas cristalinas entre montañas y pedregal' },
  { src: '/img/horseback-snow.jpeg', title: 'Cabalgata en la nieve',      desc: 'Explorando la alta montaña a caballo' },
  { src: '/img/cabin2.jpeg',         title: 'Finca en el páramo',         desc: 'Instalaciones campesinas con el pico al fondo' },
  { src: '/img/cabin-valley.jpeg',   title: 'Cabaña y laguna',            desc: 'Refugio con lagunas naturales' },
  { src: '/img/frailejon-hiker.jpeg',title: 'Entre frailejones',          desc: 'Senderismo entre los gigantes del páramo' },
  { src: '/img/valley-horses.jpeg',  title: 'Valle con caballos',         desc: 'Ganadería campesina del páramo' },
  { src: '/img/cattle-cabin.jpeg',   title: 'Ganado en el páramo',        desc: 'Vida campesina auténtica en el Nevado del Ruiz' },
  { src: '/img/cowboy-mule.jpeg',    title: 'Campesino en mula',          desc: 'Cultura campesina con ruana blanca en la nieve' },
  { src: '/img/snow-landscape.jpeg', title: 'Paisaje nevado',             desc: 'La alta montaña cubierta de nieve y frailejones' },
  { src: '/img/valley-cabin.jpeg',   title: 'Valle del páramo',           desc: 'Vista panorámica del recorrido a pie' },
  { src: '/img/snow-trek.jpeg',      title: 'Senderismo en la nieve',     desc: 'Explorando los picos nevados del Nevado del Ruiz' },
  { src: '/img/guide-horse.jpeg',    title: 'Preparando la cabalgata',    desc: 'El guía ajustando el equipo con nevado de fondo' },
  { src: '/img/paramo-fence.jpeg',   title: 'Cercas del páramo',          desc: 'El valle visto desde lo alto de la finca' },
  { src: '/img/trout-drying.jpeg',      title: 'Truchas campesinas',              desc: 'Gastronomía tradicional de la región' },
  { src: '/img/kitchen.jpeg',           title: 'Cocina campesina',                desc: 'Cocinando con vista directa al páramo' },
  { src: '/img/spring.jpeg',            title: 'Fuente artesanal',                desc: 'Agua pura de la montaña' },
  // Nuevas imágenes img2
  { src: '/img/horse-nevado.jpeg',      title: 'Desde el lomo del caballo',       desc: 'El Nevado del Ruiz visto en cabalgata' },
  { src: '/img/dawn-valley.jpeg',       title: 'Amanecer dorado',                 desc: 'El valle nevado iluminado al amanecer' },
  { src: '/img/dawn-snow-cabin.jpeg',   title: 'Cabaña en la nieve',              desc: 'Amanecer invernal sobre la finca' },
  { src: '/img/nevado-blue.jpeg',       title: 'Nevado del Ruiz',                 desc: 'Cielo azul despejado sobre el glaciar' },
  { src: '/img/nevado-panoramic.jpeg',  title: 'Panorámica del nevado',           desc: 'Vista de los picos nevados del volcán' },
  { src: '/img/horses-valley.jpeg',     title: 'Caballos en el valle',            desc: 'Vida campesina bajo el cielo del páramo' },
  { src: '/img/hiker-overview.jpeg',    title: 'Vista a la finca',                desc: 'Turista contemplando la cabaña y laguna' },
  { src: '/img/peak-clouds.jpeg',       title: 'Pico entre las nubes',            desc: 'Dramáticas nubes sobre los picos del páramo' },
  { src: '/img/aerial-frailejon.jpeg',  title: 'Vista aérea con frailejones',     desc: 'La finca vista desde los frailejones' },
  { src: '/img/hiker-frailejones2.jpeg',title: 'Senderista entre frailejones',    desc: 'Explorando la pared rocosa del páramo' },
  { src: '/img/frailejon-closeup.jpeg', title: 'Frailejón en primer plano',       desc: 'La planta insignia del páramo colombiano' },
];
---

<Layout>
  <!-- ═══════════════════════════════════════════════
       BOTÓN FLOTANTE WHATSAPP
  ═══════════════════════════════════════════════ -->
  <a
    href={WHATSAPP_URL}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar por WhatsApp"
    class="fixed bottom-6 right-6 z-50 flex items-center gap-2.5 bg-[#25D366] hover:bg-[#1ebe5d] text-white pl-4 pr-5 py-3.5 rounded-full shadow-2xl shadow-green-500/40 transition-all duration-300 hover:scale-105 hover:-translate-y-0.5 group"
  >
    <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
      ></path>
    </svg>
    <span class="font-semibold text-sm hidden sm:inline">Reservar ahora</span>
  </a>

  <!-- ═══════════════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════════════ -->
  <nav
    id="navbar"
    class="fixed top-0 left-0 right-0 z-40 transition-all duration-500 bg-transparent"
  >
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-4 flex items-center justify-between gap-4">
      <!-- Logo -->
      <a href="#inicio" class="font-serif leading-tight text-white flex-shrink-0">
        <span class="block text-lg font-bold">Los Páramos</span>
        <span class="block text-sm font-normal text-green-400 -mt-0.5">de Dios</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/80 hover:text-white text-sm font-medium transition-colors tracking-wide"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Desktop WA button -->
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-all duration-300 flex-shrink-0"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
          ></path>
        </svg>
        WhatsApp
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="md:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Abrir menú"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="icon-close"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-green-950/98 backdrop-blur-md border-t border-white/10"
    >
      <ul class="px-6 py-5 space-y-1">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="block text-white/80 hover:text-white hover:bg-white/5 py-3 px-2 rounded-lg text-sm font-medium transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="pt-3 border-t border-white/10">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#25D366] text-white text-sm font-semibold px-5 py-3 rounded-full"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Contactar por WhatsApp
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <main>
    <!-- ═══════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════ -->
    <section
      id="inicio"
      class="relative min-h-screen flex items-center justify-center overflow-hidden"
    >
      <div class="absolute inset-0 z-0">
        <img
          src="/img/horse-nevado.jpeg"
          alt="Cabalgata hacia el Nevado del Ruiz entre frailejones"
          class="w-full h-full object-cover object-[center_40%]"
        />
        <div
          class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/45 to-black/85"
        >
        </div>
        <div class="absolute inset-0 bg-gradient-to-r from-green-950/50 to-transparent"></div>
      </div>

      <div class="relative z-10 text-center text-white px-6 max-w-4xl mx-auto pt-24 pb-20">
        <div
          class="inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-5 py-2 text-sm mb-8 text-white/90"
        >
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse flex-shrink-0"></span>
          🏔️ Nevado del Ruiz · Manizales, Colombia
        </div>

        <h1 class="font-serif font-bold leading-[1.05] mb-5">
          <span class="block text-5xl sm:text-6xl md:text-7xl lg:text-8xl">Los Páramos</span>
          <span class="block text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-green-400"
            >de Dios</span
          >
        </h1>

        <p class="font-serif italic text-xl md:text-2xl text-white/70 mb-12 font-light">
          "Donde la naturaleza habla y el alma escucha"
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 shadow-xl shadow-green-500/30 hover:shadow-green-500/50 hover:-translate-y-0.5 text-base"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Reservar por WhatsApp
          </a>
          <a
            href="#experiencias"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-white/40 hover:bg-white/10 backdrop-blur-sm text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 text-base"
          >
            Ver experiencias
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
        </div>
      </div>

      <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1 text-white/40 animate-bounce"
      >
        <span class="text-xs tracking-wider uppercase">Desliza</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         STATS BAR
    ═══════════════════════════════════════════════ -->
    <div class="bg-green-950 py-10 border-y border-green-900/60">
      <div class="max-w-5xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="font-serif text-3xl md:text-4xl font-bold text-green-400">+3.900</div>
          <div class="text-white/50 text-sm mt-1">metros sobre el nivel del mar</div>
        </div>
        <div>
          <div class="font-serif text-3xl md:text-4xl font-bold text-green-400">100%</div>
          <div class="text-white/50 text-sm mt-1">naturaleza auténtica</div>
        </div>
        <div>
          <div class="font-serif text-3xl md:text-4xl font-bold text-green-400">4</div>
          <div class="text-white/50 text-sm mt-1">experiencias únicas</div>
        </div>
        <div>
