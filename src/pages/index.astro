<script>
  // Navbar: cambio de fondo al hacer scroll
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      navbar?.classList.add('bg-green-950/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/20');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove(
        'bg-green-950/95',
        'backdrop-blur-md',
        'shadow-lg',
        'shadow-black/20'
      );
      navbar?.classList.add('bg-transparent');
    }
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  menuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // Cerrar menu mobile al hacer click en un enlace
  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // ─── LIGHTBOX ────────────────────────────────────────────────
  // Construir el array de imágenes leyendo los data-attributes del DOM
  const galleryImages = Array.from(document.querySelectorAll('[data-lightbox-idx]'))
    .sort(
      (a, b) =>
        parseInt((a as HTMLElement).dataset.lightboxIdx ?? '0') -
        parseInt((b as HTMLElement).dataset.lightboxIdx ?? '0')
    )
    .map((btn) => ({
      src: (btn as HTMLElement).dataset.lightboxSrc ?? '',
      title: (btn as HTMLElement).dataset.lightboxTitle ?? '',
      desc: (btn as HTMLElement).dataset.lightboxDesc ?? '',
    }));

  let lbCurrentIdx = 0;

  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img') as HTMLImageElement | null;
  const lbTitle = document.getElementById('lb-title');
  const lbDesc = document.getElementById('lb-desc');
  const lbCounter = document.getElementById('lb-counter');

  function lbUpdate() {
    const item = galleryImages[lbCurrentIdx];
    if (lbImg) { lbImg.src = item.src; lbImg.alt = item.title; }
    if (lbTitle) lbTitle.textContent = item.title;
    if (lbDesc) lbDesc.textContent = item.desc;
    if (lbCounter) lbCounter.textContent = `${lbCurrentIdx + 1} / ${galleryImages.length}`;
  }

  function lbOpen(idx: number) {
    lbCurrentIdx = idx;
    lbUpdate();
    lightbox?.classList.remove('hidden');
    lightbox?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function lbClose() {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Abrir al hacer click en miniatura
  document.querySelectorAll('[data-lightbox-idx]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = parseInt((btn as HTMLElement).dataset.lightboxIdx ?? '0');
      lbOpen(idx);
    });
  });

  // Cerrar
  document.getElementById('lb-close')?.addEventListener('click', lbClose);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) lbClose(); });

  // Navegación
  document.getElementById('lb-prev')?.addEventListener('click', () => {
    lbCurrentIdx = (lbCurrentIdx - 1 + galleryImages.length) % galleryImages.length;
    lbUpdate();
  });
  document.getElementById('lb-next')?.addEventListener('click', () => {
    lbCurrentIdx = (lbCurrentIdx + 1) % galleryImages.length;
    lbUpdate();
  });

  // Teclado
  document.addEventListener('keydown', (e) => {
    if (lightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') lbClose();
    if (e.key === 'ArrowLeft') {
      lbCurrentIdx = (lbCurrentIdx - 1 + galleryImages.length) % galleryImages.length;
      lbUpdate();
    }
    if (e.key === 'ArrowRight') {
      lbCurrentIdx = (lbCurrentIdx + 1) % galleryImages.length;
      lbUpdate();
    }
  });
</script>
